{
  "manifest_version": 3,
  "name": "Cat Image Replacer",
  "version": "1.0.0",
  "description": "Replaces all images on a webpage with random cat images from the Cat API",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://api.thecatapi.com/*",
    "https://cataas.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["styles.css"],
      "matches": ["<all_urls>"]
    }
  ]
}